# Build the verified OpenRouter/tool-call fork inside Docker at its pinned commit.
FROM node:22.22.3-alpine AS open-agent-sdk

RUN apk add --no-cache git
RUN git clone --quiet https://github.com/frosty-agent/open-agent-sdk-typescript.git /opt/open-agent-sdk \
  && git -C /opt/open-agent-sdk checkout --quiet 6933905657de3349ad34d88737f09807dbc4b75e
WORKDIR /opt/open-agent-sdk
RUN npm ci && npm run build

# Build-time dependencies and harness code live only in this image.
FROM node:22.22.3-alpine AS runner

RUN apk add --no-cache git
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci
COPY tsconfig.json ./
COPY src ./src
COPY open-agent-worker.mjs ./open-agent-worker.mjs
COPY --from=open-agent-sdk /opt/open-agent-sdk /opt/open-agent-sdk
RUN chmod 0444 /app/open-agent-worker.mjs && chown -R node:node /app /opt/open-agent-sdk

# At runtime mount the target repository read-only at /source and a host output directory at /reports.
# OPENROUTER_API_KEY is injected with docker -e, never copied into the image.
USER node
ENTRYPOINT ["node", "--import", "tsx", "src/container-run.ts"]
